<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>C2 Server - Panel de Control</title>
    <style>
        :root {
            --bg-color: #1a1a1d;
            --card-bg: #252426;
            --text-main: #c5c6c7;
            --accent: #00ff9d; /* Verde Hacker */
            --danger: #ff4d4d;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-main);
            font-family: 'Segoe UI', Tahoma, sans-serif;
            margin: 0;
            padding: 20px;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid #333;
            padding-bottom: 20px;
            margin-bottom: 20px;
        }

        h1 { margin: 0; color: var(--accent); text-transform: uppercase; letter-spacing: 2px;}
        
        .stats-container {
            display: flex;
            gap: 20px;
            margin-bottom: 30px;
        }

        .stat-card {
            background: var(--card-bg);
            padding: 15px;
            border-radius: 8px;
            min-width: 150px;
            text-align: center;
            box-shadow: 0 4px 6px rgba(0,0,0,0.3);
        }

        .stat-number { font-size: 2em; font-weight: bold; color: #fff; display: block;}
        .stat-label { font-size: 0.8em; text-transform: uppercase; opacity: 0.7; }

        /* Tabla de víctimas */
        .table-container {
            background: var(--card-bg);
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        }

        table { width: 100%; border-collapse: collapse; }
        
        th, td { padding: 15px; text-align: left; border-bottom: 1px solid #333; }
        th { background-color: #2d2c2e; color: var(--accent); font-weight: bold;}
        
        .status-dot { height: 10px; width: 10px; background-color: var(--accent); border-radius: 50%; display: inline-block; margin-right: 8px;}

        /* Animación de carga */
        .loading { text-align: center; padding: 20px; color: #666; }
    </style>
</head>
<body>

    <div class="header">
        <h1>C2 Server // Monitor</h1>
        <span id="serverTime" style="font-family: monospace;">Cargando hora...</span>
    </div>

    <!-- Estadísticas rápidas -->
    <div class="stats-container">
        <div class="stat-card">
            <span class="stat-number" id="totalVictims">0</span>
            <span class="stat-label">Total Conectadas</span>
        </div>
        <div class="stat-card">
            <span class="stat-number" style="color:var(--danger)" id="activeNow">0</span>
            <span class="stat-label">Activo Ahora</span>
        </div>
    </div>

    <!-- Lista de víctimas -->
    <h2>Víctimas Activas</h2>
    <div class="table-container">
        <table id="victimsTable">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>IP / Nombre Equipo</th>
                    <th>Hora de Entrada</th>
                    <th>Tiempo Activo</th>
                    <th>Estado</th>
                </tr>
            </thead>
            <tbody id="tableBody">
                <!-- Aquí se llenará con JS -->
                <tr><td colspan="5" class="loading">Conectando al servidor...</td></tr>
            </tbody>
        </table>
    </div>

    <script>
        // CONFIGURACIÓN: Cambia esto por la URL de tu script Python (ej: http://192.168.x.x:5000/api/status)
        const API_URL = "http://localhost:5000/api/victims"; 

        function updateUI() {
            fetch(API_URL)
                .then(response => response.json())
                .then(data => {
                    renderTable(data);
                    updateTime();
                })
                .catch(err => console.error("Error conectando con el servidor:", err));
        }

        function renderTable(victims) {
            const tbody = document.getElementById('tableBody');
            let html = '';
            
            if (victims.length === 0) {
                html = '<tr><td colspan="5" class="loading">Esperando conexiones...</td></tr>';
            } else {
                victims.forEach(v => {
                    // Formatear tiempo activo
                    const activeTime = v.active_time ? (v.active_time / 1000).toFixed(2) : '0.00';
                    
                    html += `
                        <tr>
                            <td>#${v.id}</td>
                            <td><strong>${v.hostname || v.ip}</strong><br><small style="color:#666">${v.os || ''}</small></td>
                            <td>${new Date(v.connect_time).toLocaleTimeString()}</td>
                            <td>${activeTime}s</td>
                            <td><span class="status-dot"></span>Activo</td>
                        </tr>
                    `;
                });
            }

            // Actualizar contadores
            document.getElementById('totalVictims').innerText = victims.length;
            document.getElementById('activeNow').innerText = victims.length;
            
            tbody.innerHTML = html;
        }

        function updateTime() {
            const now = new Date();
            document.getElementById('serverTime').innerText = now.toLocaleString();
        }

        // Actualizar cada 2 segundos
        setInterval(updateUI, 2000);
        
        // Primera carga inmediata
        updateUI();
    </script>
</body>

